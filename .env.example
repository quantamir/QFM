# Copy to backend/.env (or export in your shell) and fill in real values.
# NEVER commit the real .env file.

# Generate a key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Set to "True" only for local development.
DJANGO_DEBUG=False

# Comma-separated hostnames the app is allowed to serve.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated trusted origins for CSRF (scheme required), e.g.
# https://qfm.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=
